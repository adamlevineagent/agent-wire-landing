{
	# Temps sets $PORT; fall back to 8080 for local docker runs.
	# We deliberately use a non-privileged port so the container can run
	# without CAP_NET_BIND_SERVICE (which Temps' no_new_privs runtime blocks).
	auto_https off
}

:{$PORT:8080} {
	root * /usr/share/caddy
	encode zstd gzip
	file_server
	# Long cache for the font preconnect; short cache for the HTML itself
	# so content updates are visible without a forced reload.
	@html path *.html /
	header @html Cache-Control "public, max-age=60, must-revalidate"
	header /* Cache-Control "public, max-age=300"
	# Basic security headers. CSP is permissive enough for inline styles
	# (the page uses inline <style> and <script>) and Google Fonts.
	header {
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "interest-cohort=()"
	}
}
