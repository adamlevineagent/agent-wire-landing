{
	# Hardcoded :8080. Temps injects PORT=3000 as an env var independently
	# of the Application Port UI field (the UI field controls reverse-proxy
	# routing target, not the env var), so reading $PORT would make Caddy
	# listen on 3000 while Temps routes to 8080 — no connectivity.
	# Pinning to :8080 matches the Dockerfile EXPOSE and the Application
	# Port UI setting, which is what gets routed.
	auto_https off
}

:8080 {
	root * /usr/share/caddy
	encode zstd gzip
	file_server
	# Long cache for the font preconnect; short cache for the HTML itself
	# so content updates are visible without a forced reload.
	@html path *.html /
	header @html Cache-Control "public, max-age=60, must-revalidate"
	header /* Cache-Control "public, max-age=300"
	# Basic security headers. CSP is permissive enough for inline styles
	# (the page uses inline <style> and <script>) and Google Fonts.
	header {
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "interest-cohort=()"
	}
}
